# yt-transcriber — environment variables
# Copie este arquivo para .env e preencha com sua chave.
# O .env é lido automaticamente por src/llm_factory.py quando um modelo
# Gemini for usado via --fm / --am / --pm (ex.: gemini-2.5-flash).
#
# Gere sua chave em: https://aistudio.google.com/apikey
# A chave é necessária apenas se você for usar modelos Gemini —
# uso 100% local com Ollama não exige .env.

GOOGLE_API_KEY=
